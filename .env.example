# Database type: postgres | mysql | mariadb | mssql | sqlite
DB_TYPE=postgres

# Connection string for the target database
#
# PostgreSQL (local, no SSL):
#   DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname
#
# PostgreSQL (cloud / SSL required, e.g. Supabase, Neon):
#   DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname?sslmode=require
#
# MySQL (local, no SSL):
#   DB_CONNECTION_STRING=mysql://user:password@localhost:3306/dbname
#
# MySQL (cloud / SSL required):
#   DB_CONNECTION_STRING=mysql://user:password@host:3306/dbname?ssl=true
#
# MariaDB — same format as MySQL (mariadb:// is also accepted):
#   DB_CONNECTION_STRING=mariadb://user:password@localhost:3306/dbname
#
# SQL Server (local with self-signed cert — TrustServerCertificate added automatically):
#   DB_CONNECTION_STRING=Server=localhost,1433;Database=dbname;User Id=user;Password=pass
#
# SQL Server (explicit trust, or Azure):
#   DB_CONNECTION_STRING=Server=host,1433;Database=dbname;User Id=user;Password=pass;TrustServerCertificate=true;Encrypt=true
#
# SQLite (path to .db file):
#   DB_CONNECTION_STRING=/path/to/database.db
#
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/mydb

# Secret key for JWT signing — change this to a random 32+ character string
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Set to "false" if serving over plain HTTP (e.g. local network without TLS)
# SECURE_COOKIES=false

# Sub-path prefix if serving under a non-root URL (e.g. behind a reverse proxy).
# Omit or leave empty to serve at the root path ("/").
# Example: BASE_PATH=/strawdmin  →  app is available at http://host/strawdmin
# BASE_PATH=

# Override the directory used for internal data (app.db + backups).
# Defaults to ./data relative to the app root.
# Useful when you want the data directory outside the app folder.
# DATA_DIR=/var/lib/strawdmin
